# ---- Supabase (from Project Settings → API) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App ----
# Used to build QR code URLs and redirects. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Comma-separated list of emails allowed to access /admin.
ADMIN_EMAILS=shiftdeploy@gmail.com

# ---- Google Places API (dashboard live rating) ----
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ---- SMTP for manager alerts (set as Supabase Edge Function secrets, NOT Next.js env) ----
# Used by the send-negative-alert edge function. Gmail example shown.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=shiftdeploy@gmail.com
# SMTP_PASS=your-gmail-app-password
# ALERT_FROM_EMAIL=shiftdeploy@gmail.com
